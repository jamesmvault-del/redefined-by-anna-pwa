        aria-controls="mobile-nav-menu"
        aria-expanded="false"
      >
        <span class="bar"></span>
        <span class="bar"></span>
      </button>
    </header>

    <div class="mobile-menu-overlay" id="mobile-nav-menu">
      <nav class="mobile-nav">
        <div class="mobile-nav-dropdown">
          <div class="mobile-dropdown-header">
