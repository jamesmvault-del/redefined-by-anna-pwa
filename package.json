    <main>
      <section class="hero-section" style="min-height: 600px">
        <div class="hero-background reveal-on-scroll">
          <img
            src="../assets/images/treatments/permanent-makeup-hero.webp"
            alt="Warm glowing architectural plaster background with precise permanent makeup tools"
            class="hero-bg-img"
          />
        </div>
        <div class="hero-content" style="transform: translateY(0)">
          <p class="subtitle reveal-on-scroll reveal-delay-1">
            Pricing & Services
          </p>
          <h1 class="title reveal-on-scroll reveal-delay-2">Permanent Make-up</h1>
          <p class="description reveal-on-scroll reveal-delay-3">
            Wake up flawlessly refined. Using meticulous micro-pigmentation and microblading techniques, I create subtle, elegant enhancements tailored to your natural beauty.
          </p>
        </div>
      </section>

      <div class="pricing-container">
        
        <div class="alert-box reveal-on-scroll">
          Please note: A patch test is required 24hrs prior to treatment.
        </div>

        <!-- Eyebrows -->
        <section class="pricing-category reveal-on-scroll">
          <h2>Eyebrows</h2>
          <p class="pricing-desc">
            Define and shape your brows with beautifully subtle shading or realistic hair strokes for a consistently polished look.
          </p>
          <ul class="pricing-list">
            <li class="pricing-item">
              <span class="pricing-name">Powder</span>
              <span class="pricing-price">£250</span>
            </li>
            <li class="pricing-item">
              <span class="pricing-name">Hair Stroke</span>
              <span class="pricing-price">£300</span>
            </li>
            <li class="pricing-item">
              <span class="pricing-name">Combined</span>
              <span class="pricing-price">£350</span>
            </li>
          </ul>
        </section>

        <!-- Eyeliner -->
        <section class="pricing-category reveal-on-scroll">
          <h2>Eyeliner</h2>
          <p class="pricing-desc">
            Enhance the shape of your eyes and create the illusion of thicker, fuller lashes with delicate semi-permanent eyeliner.
          </p>
          <ul class="pricing-list">
            <li class="pricing-item">
              <span class="pricing-name">Top</span>
              <span class="pricing-price">£150</span>
            </li>
            <li class="pricing-item">
              <span class="pricing-name">Bottom</span>
              <span class="pricing-price">£150</span>
            </li>
            <li class="pricing-item">
              <span class="pricing-name">Top & Bottom</span>
              <span class="pricing-price">£250</span>
            </li>
          </ul>
        </section>

        <!-- Placeholder Image Frame 1 -->
        <div class="editorial-image-frame reveal-on-scroll" style="position: relative; padding: 1.5rem; background-color: var(--bg-color-alt); box-shadow: 0 25px 50px rgba(0, 0, 0, 0.05); border: 1px solid rgba(0,0,0,0.03);">
          <div style="overflow: hidden; border-radius: 2px;">
            <img
              src="../assets/images/treatments/permanent-eyebrows.webp"
              alt="Extreme close-up of a client receiving a precise permanent eyebrow makeup treatment"
              loading="lazy"
              style="width: 100%; height: auto; display: block; filter: contrast(1.05) sepia(10%); transform: scale(1.02); transition: transform 2s ease;"
              onmouseover="this.style.transform='scale(1)'"
              onmouseout="this.style.transform='scale(1.02)'"
            />
          </div>
          <!-- Decorative editorial accent -->
          <div style="position: absolute; bottom: -1px; right: 10%; width: 30%; height: 2px; background-color: var(--accent-color);"></div>
        </div>

        <!-- Lips -->
        <section class="pricing-category reveal-on-scroll">
          <h2>Lips</h2>
          <p class="pricing-desc">
            Restore symmetry, add a flush of healthy color, and define your natural lip border for a softly rejuvenated appearance.
          </p>
          <ul class="pricing-list">
            <li class="pricing-item">
              <span class="pricing-name">Line</span>
              <span class="pricing-price">£150</span>
            </li>
            <li class="pricing-item">
              <span class="pricing-name">Blush</span>
              <span class="pricing-price">From £275</span>
            </li>
            <li class="pricing-item">
              <span class="pricing-name">Colour</span>
              <span class="pricing-price">From £300</span>
            </li>
          </ul>
        </section>

        <!-- Eyebrow Microblading -->
        <section class="pricing-category reveal-on-scroll">
          <h2>Eyebrow Microblading</h2>
          <p class="pricing-desc">
            Microblading is a semi-permanent technique for enhancing the appearance of the eyebrows, in which pigment is scratched into the skin in fine, short strokes resembling hair, using a hand tool with a blade formed of tiny needles.
          </p>
          <ul class="pricing-list">
            <li class="pricing-item">
              <span class="pricing-name">Eyebrow Microblading</span>
              <span class="pricing-price">From £300</span>
            </li>
          </ul>
        </section>

        <!-- Placeholder Image Frame 2 -->
        <div class="editorial-image-frame reveal-on-scroll" style="position: relative; padding: 1.5rem; background-color: var(--bg-color-alt); box-shadow: 0 25px 50px rgba(0, 0, 0, 0.05); border: 1px solid rgba(0,0,0,0.03);">
          <div style="overflow: hidden; border-radius: 2px;">
            <img
              src="../assets/images/treatments/permanent-lips.webp"
              alt="Extreme close-up of a client receiving a precise permanent lip blush treatment"
              loading="lazy"
              style="width: 100%; height: auto; display: block; filter: contrast(1.05) sepia(10%); transform: scale(1.02); transition: transform 2s ease;"
              onmouseover="this.style.transform='scale(1)'"
              onmouseout="this.style.transform='scale(1.02)'"
            />
          </div>
          <!-- Decorative editorial accent -->
          <div style="position: absolute; bottom: -1px; left: 10%; width: 30%; height: 2px; background-color: var(--accent-color);"></div>
        </div>

      </div>
    </main>

    <footer id="contact" class="main-footer">
      <div class="footer-content">
