    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,400&family=Montserrat:wght@300;400&display=swap"
      rel="stylesheet"
    />
    <style>
      .pricing-container {
        max-width: 800px;
        margin: 0 auto;
        padding: 4rem 6% 8rem;
      }
      .pricing-category {
        margin-bottom: 6rem;
      }
      .pricing-category h2 {
        text-align: center;
        margin-bottom: 1.5rem;
      }
      .pricing-desc {
        text-align: center;
        margin-bottom: 3rem;
        max-width: 600px;
        margin-left: auto;
        margin-right: auto;
      }
      .pricing-list {
        list-style: none;
        padding: 0;
      }
      .pricing-item {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        padding: 1.2rem 1rem;
        border-bottom: 1px solid rgba(0, 0, 0, 0.05);
        transition: background-color 0.3s ease;
      }
      .pricing-item:nth-child(even) {
        background-color: rgba(209, 184, 165, 0.08);
      }
      .pricing-item:hover {
        background-color: rgba(209, 184, 165, 0.15);
      }
      .pricing-name {
        font-size: 1.1rem;
        color: var(--text-primary);
      }
      .pricing-price {
        font-family: var(--font-heading);
        font-size: 1.3rem;
      }
      .editorial-image-frame {
        margin-top: 4rem; 
        margin-bottom: 7rem;
      }
      @media (max-width: 768px) {
        .editorial-image-frame {
          margin-top: 2.5rem;
          margin-bottom: 4rem;
        }
      }
      .image-placeholder {
        width: 100%;
        height: 400px;
        background-color: #e8e4de;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--text-secondary);
        font-family: var(--font-body);
        font-style: italic;
        border-radius: 2px;
      }
      .alert-box {
        background-color: rgba(209, 184, 165, 0.2);
        padding: 1rem;
        text-align: center;
        border-left: 4px solid var(--accent-color);
        margin-bottom: 2rem;
        font-style: italic;
      }
    </style>
