        "provider": {
          "@type": "BeautySalon",
          "name": "Redefined By Anna",
          "address": {
            "@type": "PostalAddress",
            "streetAddress": "15 Baring Gould Way",
            "addressLocality": "Haverfordwest",
            "addressRegion": "Pembrokeshire",
            "postalCode": "SA61 2SN",
            "addressCountry": "UK"
          }
        },
        "areaServed": [
          {
            "@type": "City",
            "name": "Haverfordwest"
          },
          {
            "@type": "AdministrativeArea",
            "name": "Pembrokeshire"
          }
        ],
        "description": "Bespoke permanent make-up treatments including eyebrows, eyeliner, lips, and microblading."
      }
    </script>
    <link rel="manifest" href="../manifest.json" />
    <meta name="theme-color" content="#f7f5f2" />
    <link
      rel="icon"
      type="image/png"
      href="../assets/images/source/site-logo.png"
    />
    <link rel="apple-touch-icon" href="../assets/images/source/site-logo.png" />
    <link rel="stylesheet" href="../assets/styles/main.css" />
