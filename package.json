    <title>Permanent Make-up & Microblading Haverfordwest, Pembrokeshire | Redefined By Anna</title>
    <meta
      name="description"
      content="Expert permanent make-up and microblading clinic in Haverfordwest, Pembrokeshire. Wake up flawlessly refined with bespoke eyebrow, eyeliner, and lip blush treatments by Anna."
    />
    <meta
      name="keywords"
      content="Permanent Make-up Pembrokeshire, Microblading Haverfordwest, Lip Blush Wales, Semi-Permanent Eyeliner"
    />
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "Service",
