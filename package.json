        <div class="footer-contact">
          <p>Private Beauty Clinic</p>
          <p>Haverfordwest, Pembrokeshire</p>
          <p>hello@redefinedbyanna.com</p>
          <p>By Appointment Only</p>
        </div>
        <div class="footer-registration">
          <a
            href="https://www.hiw.org.uk/redefined-anna"
            target="_blank"
            rel="noopener noreferrer"
            class="hiw-link"
          >
            <img
              src="../assets/images/homepage/hiw-registered.png"
              alt="Healthcare Inspectorate Wales Registration"
              class="hiw-logo"
              loading="lazy"
            />
            <span>Proudly Registered with Healthcare Inspectorate Wales</span>
          </a>
        </div>
      </div>
      <div class="footer-bottom">
        <p>&copy; <span class="current-year">2026</span> Redefined By Anna. All rights reserved.</p>
      </div>
